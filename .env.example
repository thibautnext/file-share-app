# Database
DATABASE_URL=postgresql://user:password@192.168.1.4:5433/database_name

# File Storage
# Choose one: 'nas' or 'vercel-blob'
STORAGE_TYPE=nas
NAS_UPLOAD_PATH=/volume1/docker/file-share/uploads

# For Vercel Blob (optional)
BLOB_READ_WRITE_TOKEN=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cleanup Job (keep as is)
CRON_SECRET=your-secret-key-for-cron
